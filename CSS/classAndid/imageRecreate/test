body {
  background:grey;
}
.button {
  width: 400px;
  height: 300px;
  margin: 28px auto;
  position: relative;
  overflow: hidden;
  border-radius:20px;
  background-color:#E38F66;
}
     circle1{
        width: 150px;
        height: 150px;
        position:relative;
        top:50%;
        left:50%;
        transform:translate(-50%,-50%);
        border-radius: 100%;
        background: #aa445f;
    }
    half1{
        width: 150px;
        height: 150px;
        position:relative;
        top:50%;
        left:50%;
        transform:rotate(-50%,-50%);
        border-radius: 50%;
        background:#F7EC7D;
    }
    half2{ 
        width: 150px;
        height: 150px;
        position:relative;
        top:50%;
        left:50%;
        transform:rotate(180deg);
        border-radius: 50%;
        background:#F7EC7D;
    }
     
