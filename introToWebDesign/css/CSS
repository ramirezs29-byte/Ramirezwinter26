<!DOCTYPE html>
<html>
<head> 
    <tittle>Class and ID stylingchallenge</title>
        <style>
            /*1.Main title*/
            #main-title{
                color:blue;
                text-align:center;
            }   
            /*2.Highlight class*/
            #special-btn{
                background-color:red;
                color:white;
                border-radius:8px;
            }
            /*3.special button*/
            #special-btn{
                background-color:red
                color:white;
                border-radius:8px;  
            }
            /*4.combo paragraph*/
            #combo{
                border:2px solid black;
                font-style:italic;
            }
        </style>
</head>
<body>
    <h1 id="main-title">Welcome to My Page</h1>
    <p class="highlight">This paragraph should demonstrate CSS styling.</p>
    <p>This paragraph should look normla.</p>
    <p> class="highlight">This one should also start with a red background and white text.</p>
    <button id="special-btn">Click Me!</button>
    <button class="highlight">I'm highlighted to stand out!</button>
    <p id="combo" class="highlight">I'm highlighted to stand out and also have a border and italic font style.</p>
</body> 
</html>